<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
<title>NameCard Connect</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js"></script>
<style>
:root{--b:#3B82F6;--bd:#2563EB;--bl:#BFDBFE;--bg:#EBF5FF;--w:#fff;--g1:#F9FAFB;--g2:#E5E7EB;--g4:#9CA3AF;--g6:#4B5563;--g8:#1F2937}
*{box-sizing:border-box;margin:0;padding:0}
body{font-family:-apple-system,'Hiragino Sans','Yu Gothic','Meiryo',sans-serif;background:linear-gradient(135deg,#DBEAFE,#EDE9FE);min-height:100vh;display:flex;justify-content:center}
.app{width:100%;max-width:430px;min-height:100vh;background:var(--bg);display:flex;flex-direction:column}

/* Header */
.hdr{background:var(--w);padding:14px 20px;display:flex;align-items:center;justify-content:space-between;box-shadow:0 1px 8px rgba(0,0,0,.07);position:sticky;top:0;z-index:100}
.brand{font-size:20px;font-weight:800;letter-spacing:-.5px;color:var(--g8)}.brand span{color:var(--b)}
.av{width:36px;height:36px;border-radius:50%;background:linear-gradient(135deg,var(--b),#60A5FA);border:2px solid var(--bl);cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:15px;font-weight:700;color:#fff;overflow:hidden;background-size:cover;background-position:center}

/* Main */
.main{flex:1;padding:14px;display:flex;flex-direction:column;gap:14px;padding-bottom:24px}

/* Quick Actions */
.qa{background:var(--w);border-radius:16px;padding:6px;box-shadow:0 2px 12px rgba(59,130,246,.1)}
.qb{display:flex;align-items:center;gap:12px;padding:11px 12px;border:none;background:none;cursor:pointer;border-radius:10px;width:100%;transition:background .15s}
.qb:hover{background:var(--g1)}.qb:active{background:var(--g2)}
.qi{width:40px;height:40px;border-radius:10px;background:linear-gradient(135deg,#DBEAFE,#BFDBFE);display:flex;align-items:center;justify-content:center;flex-shrink:0}
.qi svg{width:22px;height:22px}
.ql{font-size:15px;font-weight:600;color:var(--g8);text-align:left}
.qdv{height:1px;background:var(--g2);margin:0 12px}

/* Cards Section - 縦スクロール最適化 */
.cs{background:var(--w);border-radius:16px;padding:14px 0 10px;box-shadow:0 2px 12px rgba(59,130,246,.1);display:flex;flex-direction:column;max-height:60vh}
.csh{display:flex;align-items:center;padding:0 16px;margin-bottom:10px;flex-shrink:0}
.cst{font-size:12px;font-weight:700;color:var(--g4);text-transform:uppercase;letter-spacing:.5px}
.bdg{background:var(--b);color:#fff;font-size:11px;font-weight:700;padding:2px 8px;border-radius:10px;margin-left:auto}

/* 縦並びのリストコンテナ */
.car{display:flex;flex-direction:column;overflow-y:auto;scroll-snap-type:y mandatory;-webkit-overflow-scrolling:touch;gap:16px;padding:4px 16px 14px;flex:1}
.car::-webkit-scrollbar{width:4px}
.car::-webkit-scrollbar-thumb{background:var(--g2);border-radius:2px}

/* Business Card (横長・縦に並ぶ) */
.bc{scroll-snap-align:start;flex-shrink:0;width:100%;background:var(--w);border-radius:16px;box-shadow:0 4px 16px rgba(0,0,0,#08);position:relative;overflow:hidden;cursor:pointer;border:1px solid var(--g2);display:flex;flex-direction:column}
.bc.active-card{border-color:var(--b);box-shadow:0 4px 20px rgba(59,130,246,.15)}
.bca{position:absolute;bottom:-22px;right:-22px;width:100px;height:100px;border-radius:50%;opacity:.13}
.bci{padding:14px;display:flex;gap:12px;position:relative;z-index:1}
.bcp{width:56px;height:56px;border-radius:50%;flex-shrink:0;display:flex;align-items:center;justify-content:center;font-size:20px;font-weight:700;color:#fff;margin-top:2px;overflow:hidden;background-size:cover;background-position:center}
.bcin{flex:1;min-width:0}
.bcn{font-size:18px;font-weight:800;color:var(--g8);letter-spacing:-.3px;margin-bottom:1px}
.bco{font-size:11px;color:var(--g4);margin-bottom:2px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.bct{font-size:12px;color:var(--g6);margin-bottom:9px}
.bcrs{display:flex;flex-direction:column;gap:5px}
.bcr{display:flex;align-items:center;gap:6px}
.bcr svg{width:13px;height:13px;flex-shrink:0}
.bcr span{font-size:11px;color:var(--g6);white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.emp{display:flex;flex-direction:column;align-items:center;justify-content:center;padding:40px;gap:10px;text-align:center;color:var(--g4)}
.emp svg{width:40px;height:40px;stroke:var(--g4)}.emp h3{font-size:15px}

/* 追加された名刺画像枠 */
.bc-photo{width:100%;height:140px;background-size:cover;background-position:center;border-top:1px dashed var(--g2);background-color:var(--g1)}

/* Card Actions */
.ca{display:flex;justify-content:space-around;padding:8px 8px 4px;border-top:1px solid var(--g2);flex-shrink:0;background:var(--w);border-radius:0 0 16px 16px}
.cab{display:flex;flex-direction:column;align-items:center;gap:3px;border:none;background:none;cursor:pointer;padding:4px 5px;border-radius:8px;transition:background .15s;flex:1}
.cab:hover{background:var(--g1)}.cab svg{width:20px;height:20px}.cal{font-size:9.5px;color:var(--g6)}

/* New Card Button */
.ncb{width:100%;padding:15px;background:linear-gradient(135deg,var(--b),var(--bd));color:#fff;border:none;border-radius:14px;font-size:16px;font-weight:700;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:8px;box-shadow:0 4px 16px rgba(59,130,246,.35);transition:opacity .15s,transform .1s;font-family:inherit}
.ncb:hover{opacity:.9}.ncb:active{transform:scale(.97)}.ncb svg{width:20px;height:20px}

/* Centered Modals */
.mov{display:none;position:fixed;inset:0;background:rgba(0,0,0,.45);z-index:999;align-items:center;justify-content:center;backdrop-filter:blur(3px)}
.mov.on{display:flex}
.mdl{background:var(--w);border-radius:22px;padding:22px;width:calc(100% - 40px);max-width:350px;max-height:85vh;overflow-y:auto;position:relative;animation:su .25s ease}
@keyframes su{from{transform:translateY(18px);opacity:0}to{transform:translateY(0);opacity:1}}
.mcl{position:absolute;top:13px;right:13px;width:28px;height:28px;border-radius:50%;background:var(--g2);border:none;cursor:pointer;font-size:13px;display:flex;align-items:center;justify-content:center;color:var(--g6)}
.mtt{font-size:18px;font-weight:800;color:var(--g8);margin-bottom:18px;text-align:center}

/* QR Modal */
.qrw{display:flex;flex-direction:column;align-items:center;gap:14px}
#qrC{padding:10px;background:#fff;border-radius:10px;box-shadow:0 2px 12px rgba(0,0,0,.1);display:flex;align-items:center;justify-content:center}
.qrn{font-size:17px;font-weight:700;color:var(--g8);text-align:center}.qrs{font-size:12px;color:var(--g6);text-align:center;line-height:1.4}
.brow{display:flex;gap:8px;width:100%}
.btn{flex:1;padding:12px;background:linear-gradient(135deg,var(--b),var(--bd));color:#fff;border:none;border-radius:12px;font-size:14px;font-weight:700;cursor:pointer;font-family:inherit}
.btn2{flex:1;padding:12px;background:linear-gradient(135deg,#8B5CF6,#7C3AED);color:#fff;border:none;border-radius:12px;font-size:14px;font-weight:700;cursor:pointer;font-family:inherit}
.btnf{width:100%;padding:13px;background:linear-gradient(135deg,var(--b),var(--bd));color:#fff;border:none;border-radius:12px;font-size:15px;font-weight:700;cursor:pointer;font-family:inherit;margin-top:6px}
.btx{width:100%;padding:11px;background:none;border:none;color:var(--g4);font-size:14px;cursor:pointer;margin-top:4px}

/* Scan Area */
.sa{background:#111827;border-radius:14px;height:200px;display:flex;align-items:center;justify-content:center;position:relative;overflow:hidden;margin-bottom:10px}
.sf{width:140px;height:140px;position:relative}
.sc{position:absolute;width:20px;height:20px;border:3px solid var(--b)}
.tl{top:0;left:0;border-right:none;border-bottom:none;border-radius:3px 0 0 0}
.tr{top:0;right:0;border-left:none;border-bottom:none;border-radius:0 3px 0 0}
.bl{bottom:0;left:0;border-right:none;border-top:none;border-radius:0 0 0 3px}
.br{bottom:0;right:0;border-left:none;border-top:none;border-radius:0 0 3px 0}
.sl{position:absolute;left:0;right:0;height:2px;background:var(--b);box-shadow:0 0 8px var(--b);animation:sca 1.8s ease-in-out infinite}
@keyframes sca{0%{top:2px}50%{top:136px}100%{top:2px}}
.shi{text-align:center;font-size:12px;color:var(--g4);margin:0 0 12px}

/* Bottom Sheets */
.bov{display:none;position:fixed;inset:0;background:rgba(0,0,0,.38);z-index:999}
.bov.on{display:block}
.bsh{position:absolute;bottom:0;left:50%;transform:translateX(-50%);width:100%;max-width:430px;background:var(--w);border-radius:24px 24px 0 0;padding:18px 18px 32px;max-height:88vh;overflow-y:auto;animation:bsu .27s ease}
@keyframes bsu{from{transform:translateX(-50%) translateY(100%)}to{transform:translateX(-50%) translateY(0)}}
.bh{width:36px;height:4px;background:var(--g2);border-radius:2px;margin:0 auto 16px}
.bti{font-size:18px;font-weight:800;color:var(--g8);margin-bottom:16px}

/* Forms */
.fg{margin-bottom:12px}.fl{font-size:12px;font-weight:600;color:var(--g6);margin-bottom:5px;display:block}
.fi{width:100%;padding:10px 12px;border:1.5px solid var(--g2);border-radius:10px;font-size:14px;color:var(--g8);outline:none;font-family:inherit}
.fi:focus{border-color:var(--b)}.fr{display:grid;grid-template-columns:1fr 1fr;gap:8px}
textarea.fi{resize:vertical;min-height:80px}

/* Profile */
.ph{display:flex;flex-direction:column;align-items:center;gap:8px;margin-bottom:16px}
.pav{width:74px;height:74px;border-radius:50%;background:linear-gradient(135deg,var(--b),#60A5FA);display:flex;align-items:center;justify-content:center;font-size:26px;font-weight:700;color:#fff;position:relative;cursor:pointer;background-size:cover;background-position:center;overflow:hidden}
.ped{position:absolute;bottom:0;right:0;width:22px;height:22px;background:var(--w);border-radius:50%;display:flex;align-items:center;justify-content:center;box-shadow:0 1px 4px rgba(0,0,0,.2);font-size:11px}

/* Toast */
.tst{position:fixed;bottom:80px;left:50%;transform:translateX(-50%) translateY(8px);background:rgba(31,41,55,.9);color:#fff;padding:9px 18px;border-radius:20px;font-size:13px;font-weight:600;opacity:0;transition:all .27s;z-index:9999;pointer-events:none;white-space:nowrap}
.tst.on{opacity:1;transform:translateX(-50%) translateY(0)}

/* 非表示のファイル入力 */
.hidden-input { display: none; }
</style>
</head>
<body>
<div class="app">
  <header class="hdr">
    <div class="brand">NameCard <span>Connect</span></div>
    <div class="av" id="hdrAv" onclick="openM('profM')">山</div>
  </header>
  
  <main class="main">
    <div class="qa">
      <button class="qb" onclick="showMyQR()">
        <div class="qi">
          <svg viewBox="0 0 24 24" fill="none" stroke="#3B82F6" stroke-width="2">
            <rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/>
            <rect x="5" y="5" width="3" height="3" fill="#3B82F6" stroke="none"/>
            <rect x="16" y="5" width="3" height="3" fill="#3B82F6" stroke="none"/>
            <rect x="5" y="16" width="3" height="3" fill="#3B82F6" stroke="none"/>
            <path d="M14 14h2v2h-2zM18 14h2M14 18h2M18 18h2v-2M17 16h-1" stroke-width="1.5"/>
          </svg>
        </div>
        <span class="ql">私のQRコードを表示</span>
      </button>
      <div class="qdv"></div>
      <button class="qb" onclick="openM('scanQrM')">
        <div class="qi">
          <svg viewBox="0 0 24 24" fill="none" stroke="#3B82F6" stroke-width="2" stroke-linecap="round">
            <path d="M3 7V5a2 2 0 012-2h2M17 3h2a2 2 0 012 2v2M21 17v2a2 2 0 01-2 2h-2M7 21H5a2 2 0 01-2-2v-2"/>
            <rect x="7" y="7" width="10" height="10" rx="1.5"/>
          </svg>
        </div>
        <span class="ql">相手のQRを読み取る</span>
      </button>
      <div class="qdv"></div>
      <button class="qb" onclick="openM('scanCM')">
        <div class="qi">
          <svg viewBox="0 0 24 24" fill="none" stroke="#3B82F6" stroke-width="2" stroke-linecap="round">
            <rect x="2" y="7" width="20" height="13" rx="2"/><line x1="2" y1="11" x2="22" y2="11"/>
            <line x1="6" y1="15" x2="8" y2="15"/><line x1="10" y1="15" x2="13" y2="15"/>
          </svg>
        </div>
        <span class="ql">紙名刺をスキャン</span>
      </button>
    </div>

    <div class="cs">
      <div class="csh">
        <span class="cst">受け取った名刺（上下スクロール）</span>
        <span class="bdg" id="cnt">0</span>
      </div>
      
      <div class="car" id="car"></div>
      
      <div class="ca">
        <button class="cab" onclick="actMemo()"><svg viewBox="0 0 24 24" fill="none" stroke="#3B82F6" stroke-width="2"><path d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7"/><path d="M18.5 2.5a2.1 2.1 0 013 3L12 15l-4 1 1-4z"/></svg><span class="cal">メモを追加</span></button>
        <button class="cab" onclick="triggerCardPhoto()"><svg viewBox="0 0 24 24" fill="none" stroke="#3B82F6" stroke-width="2"><path d="M23 19a2 2 0 01-2 2H3a2 2 0 01-2-2V8a2 2 0 012-2h4l2-3h6l2 3h4a2 2 0 012 2z"/><circle cx="12" cy="13" r="4"/></svg><span class="cal">写真を登録</span></button>
        <button class="cab" onclick="actContact()"><svg viewBox="0 0 24 24" fill="none" stroke="#3B82F6" stroke-width="2"><path d="M16 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="8.5" cy="7" r="4"/><line x1="20" y1="8" x2="20" y2="14"/><line x1="23" y1="11" x2="17" y2="11"/></svg><span class="cal">連絡先保存</span></button>
        <button class="cab" onclick="actDel()"><svg viewBox="0 0 24 24" fill="none" stroke="#EF4444" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 01-2 2H8a2 2 0 01-2-2L5 6"/><path d="M10 11v6M14 11v6"/></svg><span class="cal" style="color:#EF4444">削除</span></button>
      </div>
    </div>

    <div>
      <button class="ncb" onclick="openB('addM')">
        <svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round"><rect x="2" y="7" width="20" height="13" rx="2"/><line x1="2" y1="11" x2="22" y2="11"/><line x1="12" y1="15" x2="12" y2="19"/><line x1="10" y1="17" x2="14" y2="17"/></svg>
        新しい名刺を手動で追加
      </button>
    </div>
  </main>
</div>

<div class="tst" id="tst"></div>

<input type="file" id="profilePhotoFile" class="hidden-input" accept="image/*" capture="user" onchange="loadProfilePhoto(event)">
<input type="file" id="cardPhotoFile" class="hidden-input" accept="image/*" capture="environment" onchange="loadCardPhoto(event)">

<div class="mov" id="qrM" onclick="if(event.target===this)closeM('qrM')">
  <div class="mdl">
    <button class="mcl" onclick="closeM('qrM')">✕</button>
    <h2 class="mtt">私のQRコード</h2>
    <div class="qrw">
      <div id="qrC"></div> <div class="qrn" id="qrNm">山田 花子</div>
      <div class="qrs">このQRコードを相手のスマホカメラやLINE、インスタのカメラで読み取ってもらうと情報が伝わります。</div>
      <div class="brow">
        <button class="btn2" onclick="toast('🔗 リンクをコピーしました')">シェア</button>
        <button class="btn" onclick="closeM('qrM')">閉じる</button>
      </div>
    </div>
  </div>
</div>

<div class="mov" id="scanQrM" onclick="if(event.target===this)closeM('scanQrM')">
  <div class="mdl">
    <button class="mcl" onclick="closeM('scanQrM')">✕</button>
    <h2 class="mtt">QRコードを読み取る</h2>
    <div class="sa">
      <div class="sf">
        <div class="sc tl"></div><div class="sc tr"></div>
        <div class="sc bl"></div><div class="sc br"></div>
        <div class="sl"></div>
      </div>
    </div>
    <p class="shi">相手のQRコードをカメラに向けてください</p>
    <button class="btnf" onclick="simQR()">デモ：QRコードを自動読込</button>
  </div>
</div>

<div class="mov" id="scanCM" onclick="if(event.target===this)closeM('scanCM')">
  <div class="mdl">
    <button class="mcl" onclick="closeM('scanCM')">✕</button>
    <h2 class="mtt">紙名刺をスキャン</h2>
    <div class="sa">
      <div style="position:absolute;inset:16px;border:2px dashed rgba(255,255,255,.3);border-radius:8px;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:8px">
        <svg viewBox="0 0 24 24" style="width:28px;height:28px" fill="none" stroke="rgba(255,255,255,.45)" stroke-width="1.5"><rect x="2" y="7" width="20" height="13" rx="2"/><line x1="2" y1="11" x2="22" y2="11"/></svg>
        <span style="font-size:12px;color:rgba(255,255,255,.45)">名刺を枠内に入れてください</span>
      </div>
      <div class="sl"></div>
    </div>
    <p class="shi">名刺を水平に置いてカメラに向けてください</p>
    <button class="btnf" onclick="simCard()">デモ：スキャンして自動文字起こし</button>
  </div>
</div>

<div class="mov" id="profM" onclick="if(event.target===this)closeM('profM')">
  <div class="mdl">
    <button class="mcl" onclick="closeM('profM')">✕</button>
    <h2 class="mtt">マイ名刺のカスタマイズ</h2>
    <div class="ph">
      <div class="pav" id="pAv" onclick="document.getElementById('profilePhotoFile').click()">山
        <div class="ped">📸</div>
      </div>
      <span style="font-size:11px;color:var(--g4)">タップして自分の写真を撮影・変更</span>
    </div>
    <div class="fg"><label class="fl">名前</label><div class="fr"><input class="fi" id="pln" value="山田"><input class="fi" id="pfn" value="花子"></div></div>
    <div class="fg"><label class="fl">会社名</label><input class="fi" id="pco" value="株式会社サンプル"></div>
    <div class="fg"><label class="fl">役職</label><input class="fi" id="pti" value="マーケティング部・主任"></div>
    <div class="fg"><label class="fl">メール</label><input class="fi" id="pem" type="email" value="hanako@sample.co.jp"></div>
    <button class="btnf" onclick="savePro()">プロフィールを保存</button>
  </div>
</div>

<div class="bov" id="addM" onclick="if(event.target===this)closeB('addM')">
  <div class="bsh">
    <div class="bh"></div>
    <div class="bti">名刺を手動で追加</div>
    <div class="fg"><label class="fl">お名前 ＊</label><div class="fr"><input class="fi" id="aln" placeholder="田中"><input class="fi" id="afn" placeholder="健太"></div></div>
    <div class="fg"><label class="fl">会社名</label><input class="fi" id="aco" placeholder="株式会社〇〇"></div>
    <div class="fg"><label class="fl">役職</label><input class="fi" id="ati" placeholder="営業部・部長"></div>
    <div class="fg"><label class="fl">メールアドレス</label><input class="fi" id="aem" type="email" placeholder="name@company.com"></div>
    <div class="fg"><label class="fl">電話番号</label><input class="fi" id="aph" type="tel" placeholder="03-0000-0000"></div>
    <button class="btnf" onclick="addCard()">名刺を追加する</button>
    <button class="btx" onclick="closeB('addM')">キャンセル</button>
  </div>
</div>

<div class="bov" id="memoM" onclick="if(event.target===this)closeB('memoM')">
  <div class="bsh">
    <div class="bh"></div>
    <div class="bti">メモを追加</div>
    <div class="fg"><label class="fl">現在のメモ</label><div class="md" id="mdis"><span class="me">まだメモはありません</span></div></div>
    <div class="fg"><label class="fl">新しいメモ</label><textarea class="fi" id="minp" rows="4" placeholder="会った場所、話した内容などを記録…"></textarea></div>
    <button class="btnf" onclick="saveMemo()">メモを保存する</button>
    <button class="btx" onclick="closeB('memoM')">キャンセル</button>
  </div>
</div>

<script>
// --- ローカルストレージ対応のデータ保存 ---
let myProfile = JSON.parse(localStorage.getItem('myProfile')) || {
  ln: "山田", fn: "花子", co: "株式会社サンプル", ti: "マーケティング部・主任", em: "hanako@sample.co.jp", photo: ""
};

let cards = JSON.parse(localStorage.getItem('cards')) || [
  { id: 1, ln: "佐藤", fn: "次郎", co: "テックソリューションズ株式会社", ti: "開発部 マネージャー", em: "sato@tech-sol.jp", ph: "03-1234-5678", memo: "展示会で交換。AI導入について興味ありとのこと。", color: "#3B82F6", cardPhoto: "" },
  { id: 2, ln: "鈴木", fn: "一郎", co: "鈴木デザイン事務所", ti: "代表 / アートディレクター", em: "ichiro@suzuki-des.com", ph: "090-8765-4321", memo: "パンフレットのデザインのリニューアルで相談予定。", color: "#10B981", cardPhoto: "" },
  { id: 3, ln: "高橋", fn: "恵子", co: "グローバル・マーケティング合同会社", ti: "シニアコンサルタント", em: "k.takahashi@global-mkt.co.jp", ph: "03-9876-5432", memo: "共通の知人（加藤さん）からの紹介。", color: "#8B5CF6", cardPhoto: "" }
];

let activeIndex = 0;
let qrcodeInstance = null;

// --- モーダル・ボトムシート制御 ---
function openM(id) { document.getElementById(id).classList.add('on'); }
function closeM(id) { document.getElementById(id).classList.remove('on'); }
function openB(id) { document.getElementById(id).classList.add('on'); }
function closeB(id) { document.getElementById(id).classList.remove('on'); }

function toast(msg) {
  const t = document.getElementById('tst');
  t.textContent = msg;
  t.classList.add('on');
  setTimeout(() => t.classList.remove('on'), 2000);
}

// --- 自分専用のリアルQRコードを生成して表示 ---
function showMyQR() {
  document.getElementById('qrNm').textContent = `${myProfile.ln} ${myProfile.fn}`;
  const qrContainer = document.getElementById('qrC');
  qrContainer.innerHTML = '';
  
  // 自分の名刺情報を詰めた仮想URLや文字列
  const qrData = `MECARD:N:${myProfile.ln},${myProfile.fn};ORG:${myProfile.co};TIL:${myProfile.ti};EMAIL:${myProfile.em};;`;
  
  qrcodeInstance = new QRCode(qrContainer, {
    text: qrData,
    width: 180,
    height: 180,
    colorDark: "#1F2937",
    colorLight: "#ffffff",
    correctLevel: QRCode.CorrectLevel.H
  });
  openM('qrM');
}

// --- 自分の顔写真・プロフ写真の読み込み ---
function loadProfilePhoto(event) {
  const file = event.target.files[0];
  if (!file) return;
  const reader = new FileReader();
  reader.onload = function(e) {
    myProfile.photo = e.target.result;
    saveAndRefresh();
    toast('📸 プロフィール写真を変更しました');
  }
  reader.readAsDataURL(file);
}

// --- 相手の名刺写真をカメラで撮影・登録 ---
function triggerCardPhoto() {
  if (cards.length === 0) return toast('⚠️ 名刺がありません');
  document.getElementById('cardPhotoFile').click();
}

function loadCardPhoto(event) {
  const file = event.target.files[0];
  if (!file) return;
  const reader = new FileReader();
  reader.onload = function(e) {
    cards[activeIndex].cardPhoto = e.target.result;
    saveAndRefresh();
    toast('📸 名刺に写真を登録しました');
  }
  reader.readAsDataURL(file);
}

// --- データの保存＆再描写 ---
function saveAndRefresh() {
  localStorage.setItem('myProfile', JSON.stringify(myProfile));
  localStorage.setItem('cards', JSON.stringify(cards));
  applyProfileDOM();
  renderCards();
}

function applyProfileDOM() {
  const hAv = document.getElementById('hdrAv');
  const pAv = document.getElementById('pAv');
  
  document.getElementById('pln').value = myProfile.ln;
  document.getElementById('pfn').value = myProfile.fn;
  document.getElementById('pco').value = myProfile.co;
  document.getElementById('pti').value = myProfile.ti;
  document.getElementById('pem').value = myProfile.em;

  if(myProfile.photo) {
    hAv.textContent = '';
    hAv.style.backgroundImage = `url(${myProfile.photo})`;
    pAv.textContent = '';
    pAv.style.backgroundImage = `url(${myProfile.photo})`;
    pAv.innerHTML = `<div class="ped">📸</div>`;
  } else {
    hAv.textContent = myProfile.ln[0] || '山';
    hAv.style.backgroundImage = 'none';
    pAv.textContent = myProfile.ln[0] || '山';
    pAv.style.backgroundImage = 'none';
    pAv.innerHTML = `${myProfile.ln[0]}<div class="ped">📸</div>`;
  }
}

// --- 縦並び・縦スクロール名刺のレンダリング ---
function renderCards() {
  const car = document.getElementById('car');
  const cnt = document.getElementById('cnt');
  
  car.innerHTML = '';
  cnt.textContent = cards.length;

  if (cards.length === 0) {
    car.innerHTML = `
      <div class="emp">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="7" width="20" height="13" rx="2"/><line x1="2" y1="11" x2="22" y2="11"/></svg>
        <h3>名刺がありません</h3>
      </div>`;
    return;
  }

  if (activeIndex >= cards.length) activeIndex = cards.length - 1;
  if (activeIndex < 0) activeIndex = 0;

  cards.forEach((c, idx) => {
    const bc = document.createElement('div');
    bc.className = `bc ${idx === activeIndex ? 'active-card' : ''}`;
    
    // タップされたカードを自動選択（アクティブ化）
    bc.onclick = () => {
      activeIndex = idx;
      updateActiveCardStyle();
    };

    let photoHtml = c.cardPhoto ? `<div class="bc-photo" style="background-image:url(${c.cardPhoto})"></div>` : '';

    bc.innerHTML = `
      <div class="bca" style="background:${c.color}"></div>
      <div class="bci">
        <div class="bcp" style="background:${c.color}">${c.ln[0]}</div>
        <div class="bcin">
          <div class="bcn">${c.ln} ${c.fn}</div>
          <div class="bco">${c.co}</div>
          <div class="bct">${c.ti}</div>
          <div class="bcrs">
            <div class="bcr">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
              <span>${c.em || '---'}</span>
            </div>
            <div class="bcr">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
              <span>${c.ph || '---'}</span>
            </div>
          </div>
        </div>
      </div>
      ${photoHtml}
    `;
    car.appendChild(bc);
  });
}

function updateActiveCardStyle() {
  const children = document.getElementById('car').children;
  for(let i=0; i<children.length; i++) {
    if(children[i].classList.contains('bc')) {
      children[i].classList.toggle('active-card', i === activeIndex);
    }
  }
}

// 縦スクロール時の自動追従検知
document.getElementById('car').addEventListener('scroll', function(e) {
  const nodes = Array.from(e.target.children);
  if(nodes.length === 0 || nodes[0].classList.contains('emp')) return;
  
  const containerTop = e.target.getBoundingClientRect().top;
  let closestIdx = 0;
  let minDiff = Infinity;
  
  nodes.forEach((node, idx) => {
    const diff = Math.abs(node.getBoundingClientRect().top - containerTop);
    if(diff < minDiff) {
      minDiff = diff;
      closestIdx = idx;
    }
  });
  
  if(closestIdx !== activeIndex) {
    activeIndex = closestIdx;
    updateActiveCardStyle();
  }
});

// --- 各種ボタンアクションの実装 ---
function actMemo() {
  if (cards.length === 0) return toast('⚠️ 名刺がありません');
  const c = cards[activeIndex];
  document.getElementById('mdis').innerHTML = c.memo ? c.memo : `<span class="me">まだメモはありません</span>`;
  document.getElementById('minp').value = '';
  openB('memoM');
}

function saveMemo() {
  const inp = document.getElementById('minp').value.trim();
  if (inp) {
    const c = cards[activeIndex];
    c.memo = c.memo ? c.memo + '\n' + inp : inp;
    saveAndRefresh();
    toast('💾 メモを保存しました');
  }
  closeB('memoM');
}

function actContact() {
  if (cards.length === 0) return toast('⚠️ 名刺がありません');
  toast(`👤 ${cards[activeIndex].ln} さんの連絡先をスマホに保存しました`);
}

function actDel() {
  if (cards.length === 0) return toast('⚠️ 名刺がありません');
  if (confirm(`${cards[activeIndex].ln} さんの名刺を削除しますか？`)) {
    cards.splice(activeIndex, 1);
    saveAndRefresh();
    toast('🗑️ 名刺を削除しました');
  }
}

// --- 手動追加 ---
function addCard() {
  const ln = document.getElementById('aln').value.trim();
  const fn = document.getElementById('afn').value.trim();
  const co = document.getElementById('aco').value.trim();
  const ti = document.getElementById('ati').value.trim();
  const em = document.getElementById('aem').value.trim();
  const ph = document.getElementById('aph').value.trim();

  if (!ln) return alert('お名前（姓）を入力してください');

  const colors = ['#3B82F6', '#10B981', '#8B5CF6', '#F59E0B', '#EF4444'];
  const randomColor = colors[Math.floor(Math.random() * colors.length)];

  cards.push({ id: Date.now(), ln, fn, co, ti, em, ph, memo: "", color: randomColor, cardPhoto: "" });
  activeIndex = cards.length - 1;
  
  saveAndRefresh();
  closeB('addM');
  toast('➕ 新しい名刺を追加しました');

  ['aln','afn','aco','ati','aem','aph'].forEach(id => document.getElementById(id).value = '');
}

// --- マイプロフィール保存 ---
function savePro() {
  const ln = document.getElementById('pln').value.trim();
  const fn = document.getElementById('pfn').value.trim();
  if(!ln || !fn) return alert('名前を入力してください');
  
  myProfile.ln = ln;
  myProfile.fn = fn;
  myProfile.co = document.getElementById('pco').value.trim();
  myProfile.ti = document.getElementById('pti').value.trim();
  myProfile.em = document.getElementById('pem').value.trim();
  
  saveAndRefresh();
  closeM('profM');
  toast('✅ プロフィールを更新しました');
}

